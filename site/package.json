{
  "name": "contribute-site",
  "type": "module",
  "version": "0.1.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "prebuild": "node -e \"require('fs').cpSync('../schemas', 'public/schemas', {recursive: true})\"",
    "predev": "node -e \"require('fs').cpSync('../schemas', 'public/schemas', {recursive: true})\"",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "typecheck": "astro check",
    "lint": "prettier --check src",
    "format": "prettier --write src",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.7",
    "gray-matter": "^4.0.3",
    "marked": "^18.0.2",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.0",
    "@types/node": "^22.10.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "happy-dom": "^15.11.7",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "~5.7.3",
    "vite": "^7.3.2",
    "vitest": "^2.1.8"
  }
}
