<div class="flex justify-between items-center px-6 py-3 border-b border-soil/20 bg-paper">
  <div class="font-display text-[0.9rem]">◈ Contribute · New submission</div>
  <div class="flex gap-3 items-center font-mono text-[0.72rem] text-muted">
    <span id="draft-status"
      ><span class="w-1.5 h-1.5 rounded-full bg-moss inline-block mr-1.5"></span>Draft saved locally</span
    >
    <button
      id="magic-link-btn"
      class="text-[0.75rem] px-3 py-1.5 border border-soil/30 rounded text-ink"
      >Email me a recovery link</button
    >
  </div>
</div>
<script>
  import { loadDraft } from '../../lib/draft-state';
  const el = document.getElementById('draft-status');
  if (el) {
    const d = loadDraft();
    if (d.last_saved) {
      const seconds = Math.round((Date.now() - new Date(d.last_saved).getTime()) / 1000);
      el.innerHTML = `<span class="w-1.5 h-1.5 rounded-full bg-moss inline-block mr-1.5"></span>Draft saved ${seconds < 5 ? 'just now' : `${seconds}s ago`}`;
    }
  }
</script>
