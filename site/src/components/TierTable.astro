---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
interface Row {
  tier: string;
  tag: string;
  ship: string;
  run: string;
  shipping: string;
  turnaround: string;
  link: string;
  dim?: boolean;
}
const rows: Row[] = [
  {
    tier: 'Biomass',
    tag: 'T1',
    ship: 'Freeze-dried organism (culture, isolate, voucher)',
    run: 'Bligh-Dyer + UHPLC-HRMS',
    shipping: 'Ambient',
    turnaround: '2–4 months from receipt',
    link: `${base}/sops/#biomass`
  },
  {
    tier: 'Lipid extract',
    tag: 'T2',
    ship: 'Dried organic phase under N₂',
    run: 'UHPLC-HRMS only',
    shipping: 'Dry ice',
    turnaround: '1–2 months from receipt',
    link: `${base}/sops/#extract`
  },
  {
    tier: 'Spectra',
    tag: 'T3',
    ship: '.raw / .mzML / MGF + QC',
    run: 'Alignment + annotation only',
    shipping: '—',
    turnaround: 'Linked to pipeline',
    link: 'https://pipeline.soillifeatlas.org/',
    dim: true
  }
];
---

<section class="border-b border-soil/20 py-10">
  <div class="max-w-wide mx-auto px-8">
    <div class="flex justify-between items-baseline mb-6">
      <div>
        <p class="mono-muted">§1 · Handoff tiers</p>
        <h2 class="font-display text-[1.35rem] mt-1">What can I submit?</h2>
      </div>
      <div class="font-mono text-[0.72rem] text-muted">
        Choose the tier that fits your lab's infrastructure.
      </div>
    </div>
    <table class="w-full border-collapse text-[0.85rem]">
      <thead>
        <tr class="text-left">
          <th
            class="font-mono text-[0.7rem] uppercase tracking-[0.12em] text-muted py-2 pr-3 border-b border-soil/30 font-normal"
            >Tier</th
          >
          <th
            class="font-mono text-[0.7rem] uppercase tracking-[0.12em] text-muted py-2 pr-3 border-b border-soil/30 font-normal"
            >You ship</th
          >
          <th
            class="font-mono text-[0.7rem] uppercase tracking-[0.12em] text-muted py-2 pr-3 border-b border-soil/30 font-normal"
            >We run</th
          >
          <th
            class="font-mono text-[0.7rem] uppercase tracking-[0.12em] text-muted py-2 pr-3 border-b border-soil/30 font-normal"
            >Shipping</th
          >
          <th
            class="font-mono text-[0.7rem] uppercase tracking-[0.12em] text-muted py-2 pr-3 border-b border-soil/30 font-normal"
            >Turnaround</th
          >
          <th
            class="font-mono text-[0.7rem] uppercase tracking-[0.12em] text-muted py-2 border-b border-soil/30 font-normal"
          ></th>
        </tr>
      </thead>
      <tbody>
        {
          rows.map((r) => (
            <tr class:list={['align-top', r.dim && 'opacity-55']}>
              <td class="py-2.5 pr-3 border-b border-soil/10">
                <span class="font-mono text-[0.7rem] bg-spectral/10 text-spectral px-1.5 py-0.5 rounded mr-2">
                  {r.tag}
                </span>
                <span class="font-medium">{r.tier}</span>
              </td>
              <td class="py-2.5 pr-3 border-b border-soil/10 text-[#4a4a4a]">{r.ship}</td>
              <td class="py-2.5 pr-3 border-b border-soil/10">{r.run}</td>
              <td class="py-2.5 pr-3 border-b border-soil/10">{r.shipping}</td>
              <td class="py-2.5 pr-3 border-b border-soil/10">{r.turnaround}</td>
              <td class="py-2.5 border-b border-soil/10">
                <a href={r.link} class="font-mono text-[0.82rem]">
                  {r.dim ? 'pipeline ↗' : 'SOPs →'}
                </a>
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
    <div class="mt-4 bg-[#f2ede3] border-l-2 border-spectral px-4 py-3 text-[0.85rem]">
      <strong class="font-semibold">Dry biomass weight is good-to-have, not mandatory</strong> — the quantification
      pipeline performs better with it, but T1 submissions without dry mass are accepted. Internal standards
      are <strong>required for T2</strong> (lipid extract) but optional for T1 (CeMESS spikes EquiSPLASH
      pre-extraction if none supplied).
    </div>
  </div>
</section>
