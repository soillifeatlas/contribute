---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

const schemaPath = path.resolve(process.cwd(), '../schemas/submission.schema.json');
const schema = JSON.parse(fs.readFileSync(schemaPath, 'utf8'));
const pretty = JSON.stringify(schema, null, 2);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout title="Submission schema" active="schema">
  <section class="max-w-wide mx-auto px-8 py-10">
    <p class="mono-label">/contribute/schema</p>
    <h1 class="font-display text-[2rem] mt-2">Submission schema</h1>
    <p class="text-muted mt-2 max-w-prose">JSON Schema (2020-12) for all submissions. Server validates every submission against this on submit. Download the full schema:</p>
    <div class="mt-3 flex gap-3 text-[0.85rem]">
      <a href={`${base}/schemas/submission.schema.json`} download class="btn-outline">Download submission.schema.json</a>
      <a href={`${base}/schemas/sop-frontmatter.schema.json`} download class="btn-outline">Download SOP frontmatter schema</a>
    </div>
    <pre class="bg-ink text-[#e8e5d8] font-mono text-[0.75rem] p-5 rounded overflow-x-auto mt-6 leading-relaxed"><code>{pretty}</code></pre>
  </section>
</BaseLayout>
