---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Resume draft" active="submit">
  <section class="max-w-prose mx-auto px-8 py-12" id="resume-ui">
    <p class="mono-label">/contribute/submit/draft</p>
    <h1 class="font-display text-[2rem] mt-2">Resuming your draft…</h1>
    <p class="text-muted mt-4" id="resume-msg">Fetching your draft from the server.</p>
    <a id="resume-link" href={`${base}/submit/welcome/`} class="btn-primary mt-6 hidden"
      >Continue to the wizard →</a
    >
  </section>
  <script define:vars={{ base }}>
    (async () => {
      const token = new URLSearchParams(location.search).get('token');
      const msg = document.getElementById('resume-msg');
      const link = document.getElementById('resume-link');
      if (!token) {
        if (msg) msg.textContent = 'No token provided in the URL.';
        return;
      }
      try {
        const res = await fetch(`${base}/api/drafts/${token}`);
        if (!res.ok) throw new Error('not-found');
        const draft = await res.json();
        localStorage.setItem('contribute:draft:v1', JSON.stringify(draft.state));
        if (msg) msg.textContent = 'Draft restored.';
        if (link) {
          const stepId = draft.state && draft.state.step_id ? draft.state.step_id : 'welcome';
          link.href = `${base}/submit/${stepId}/`;
          link.classList.remove('hidden');
        }
      } catch (e) {
        if (msg)
          msg.textContent = 'Draft not found, expired, or already submitted. Start fresh below.';
        if (link) {
          link.href = `${base}/submit/welcome/`;
          link.classList.remove('hidden');
          link.textContent = 'Start a new submission →';
        }
      }
    })();
  </script>
</BaseLayout>
