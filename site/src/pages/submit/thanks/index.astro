---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout title="Thank you" active="submit">
  <section class="max-w-prose mx-auto px-8 py-12">
    <p class="mono-label">/contribute/submit/thanks</p>
    <h1 class="font-display text-[2rem] mt-2">Thank you — your contribution is received</h1>
    <div class="mt-6 bg-white border border-soil/20 rounded p-5">
      <p class="text-muted text-[0.85rem]">Submission ID</p>
      <p id="submission-id" class="font-mono text-[1.2rem] mt-1">—</p>
    </div>
    <h2 class="font-display text-[1.2rem] mt-8">What happens next</h2>
    <ol class="list-decimal pl-6 mt-3 text-[0.9rem] leading-[1.75]">
      <li>You'll receive a receipt email with the full submission JSON attached.</li>
      <li>We confirm shipping details by email within 2 business days.</li>
      <li>Ship the material (<a href={`${base}/sops/_shared/shipping-logistics/`}>see shipping SOP</a> for recipient address).</li>
      <li>We confirm receipt and start the extraction + MS workflow.</li>
      <li>Your dataset is included in the next atlas release with co-authorship.</li>
    </ol>
    <div class="flex gap-3 mt-8">
      <a href={`${base}/`} class="btn-outline">Back to contribute homepage</a>
      <a href={`${base}/submit/welcome/`} class="btn-outline">Submit another</a>
    </div>
  </section>
  <script>
    const id = new URLSearchParams(window.location.search).get('id');
    const el = document.getElementById('submission-id');
    if (el && id) el.textContent = id;
  </script>
</BaseLayout>
